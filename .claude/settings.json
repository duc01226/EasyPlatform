{
    "cleanupPeriodDays": 30,
    "skillListingBudgetFraction": 0.05,
    "env": {
        "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
        "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "250000",
        "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
        "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
        "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "1000",
        "MCP_TIMEOUT": "30000"
    },
    "attribution": {
        "commit": "Generated with [Claude Code](https://claude.com/claude-code)",
        "pr": "Generated with [Claude Code](https://claude.com/claude-code)"
    },
    "includeCoAuthoredBy": false,
    "permissions": {
        "allow": ["Edit(.claude/**)", "Write(.claude/**)", "Bash(tmp/**)", "Edit(tmp/**)", "Read(tmp/**)", "Write(tmp/**)", "Glob(tmp/**)"],
        "deny": [
            "Bash(rm -rf /*)",
            "Bash(rm -rf ~/*)",
            "Bash(rm -rf .)",
            "Bash(rm -rf /)",
            "Bash(*rm -rf:*)",
            "Bash(del /s:*)",
            "Bash(*del /s:*)",
            "Bash(git push --force:*)",
            "Bash(*git push --force:*)",
            "Bash(git push -f:*)",
            "Bash(*git push -f:*)",
            "Bash(git reset:*)",
            "Bash(*git reset:*)",
            "Bash(git clean -fd:*)",
            "Bash(*git clean -fd:*)",
            "Bash(git clean -f:*)",
            "Bash(*git clean -f:*)",
            "Bash(git branch -D:*)",
            "Bash(*git branch -D:*)",
            "Bash(git stash drop:*)",
            "Bash(*git stash drop:*)",
            "Bash(git checkout -- .)",
            "Bash(*git checkout -- .)",
            "Bash(git checkout -- :*)",
            "Bash(*git checkout --:*)",
            "Bash(git restore .)",
            "Bash(*git restore .)",
            "Bash(git restore --staged:*)",
            "Bash(*git restore --staged:*)",
            "Edit(**/.git/**)",
            "Edit(.git/**)",
            "Edit(**/.env!(.example))",
            "Edit(.env!(.example))",
            "Edit(**/secrets/**)",
            "Edit(**/credentials*)",
            "Edit(**/generated/**)",
            "Edit(**/obj/**)",
            "Edit(**/bin/**)",
            "Edit(**/dist/**)",
            "Edit(**/node_modules/**)",
            "Read(**/.git/**)",
            "Read(.git/**)",
            "Read(**/.env!(.example))",
            "Read(.env!(.example))",
            "Read(**/secrets/**)",
            "Read(**/credentials*)",
            "Read(~/.ssh/**)",
            "Read(~/.aws/**)",
            "Read(~/.config/gcloud/**)",
            "Write(**/.git/**)",
            "Write(.git/**)",
            "Write(**/.env!(.example))",
            "Write(.env!(.example))",
            "Write(**/secrets/**)",
            "Write(**/credentials*)",
            "Write(**/generated/**)",
            "Write(**/obj/**)",
            "Write(**/bin/**)",
            "Write(**/dist/**)",
            "Write(**/node_modules/**)"
        ],
        "ask": ["Bash(git push:*)", "Bash(npm publish:*)", "Bash(docker push:*)"],
        "defaultMode": "bypassPermissions"
    },
    "enableAllProjectMcpServers": false,
    "enabledMcpjsonServers": ["context7", "github", "mongodb", "postgres"],
    "disabledMcpjsonServers": ["chrome-devtools", "figma", "sequential-thinking"],
    "hooks": {
        "Notification": [
            {
                "matcher": "AskUserPrompt|permission_prompt",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notifications/notify.cjs"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-prettier.cjs"
                    }
                ]
            },
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/graph-auto-update.cjs"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "AskUserQuestion",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notifications/notify.cjs"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/windows-command-detector.cjs"
                    },
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-commit-block.cjs"
                    },
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-sync-gate.cjs"
                    }
                ]
            },
            {
                "matcher": "Bash|Glob|Grep|Read|Edit|Write|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scout-block.cjs"
                    },
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/privacy-block.cjs"
                    }
                ]
            },
            {
                "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/path-boundary-block.cjs"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-sync-gate.cjs"
                    }
                ]
            },
            {
                "matcher": "mcp__filesystem__*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/path-boundary-block.cjs"
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "matcher": "clear|exit|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.cjs"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "startup|resume|clear|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verify-install.cjs"
                    }
                ]
            },
            {
                "matcher": "startup|resume|clear|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-init.cjs"
                    }
                ]
            },
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/npm-auto-install.cjs"
                    }
                ]
            },
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-init-docs.cjs"
                    }
                ]
            },
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/graph-session-init.cjs"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notifications/notify.cjs"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/init-prompt-gate.cjs"
                    }
                ]
            }
        ]
    },
    "workflowKeywordTriggerEnabled": false,
    "statusLine": {
        "type": "command",
        "command": "npx -y ccstatusline@latest --config .claude/ccstatusline.json",
        "padding": 0
    },
    "enabledPlugins": {
        "code-review@claude-plugins-official": false,
        "code-simplifier@claude-plugins-official": false,
        "commit-commands@claude-plugins-official": true,
        "csharp-lsp@claude-plugins-official": false,
        "frontend-design@claude-plugins-official": false,
        "github@claude-plugins-official": true,
        "playwright@claude-plugins-official": false,
        "typescript-lsp@claude-plugins-official": false,
        "superpowers@claude-plugins-official": true
    },
    "alwaysThinkingEnabled": true,
    "effortLevel": "high",
    "autoMemoryEnabled": false
}
