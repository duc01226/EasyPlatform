    "includeCoAuthoredBy": false,
    "model": "sonnet",
    "permissions": {
        "allow": ["Edit(.claude/**)", "Bash(tmp/**)", "Edit(tmp/**)", "Read(tmp/**)", "Write(tmp/**)", "Glob(tmp/**)"],
        "ask": ["Bash(git push:*)", "Bash(npm publish:*)", "Bash(docker push:*)"],
        "defaultMode": "bypassPermissions",
        "deny": [
            "Bash(rm -rf /*)",
            "Bash(rm -rf ~/*)",
            "Bash(rm -rf .)",
            "Bash(rm -rf /)",
            "Bash(*rm -rf:*)",
            "Bash(del /s:*)",
            "Bash(*del /s:*)",
            "Bash(git push --force:*)",
            "Bash(*git push --force:*)",
            "Bash(git push -f:*)",
            "Bash(*git push -f:*)",
            "Bash(git reset:*)",
            "Bash(*git reset:*)",
            "Bash(git clean -fd:*)",
            "Bash(*git clean -fd:*)",
            "Bash(git clean -f:*)",
            "Bash(*git clean -f:*)",
            "Bash(git branch -D:*)",
            "Bash(*git branch -D:*)",
            "Bash(git stash drop:*)",
            "Bash(*git stash drop:*)",
            "Bash(git checkout -- .)",
            "Bash(*git checkout -- .)",
            "Bash(git checkout -- :*)",
            "Bash(*git checkout --:*)",
            "Bash(git restore .)",
            "Bash(*git restore .)",
            "Bash(git restore --staged:*)",
            "Bash(*git restore --staged:*)",
            "Edit(**/.git/**)",
            "Edit(.git/**)",
            "Edit(**/.env!(.example))",
            "Edit(.env!(.example))",
            "Edit(**/secrets/**)",
            "Edit(**/credentials*)",
            "Edit(**/generated/**)",
            "Edit(**/obj/**)",
            "Edit(**/bin/**)",
            "Edit(**/dist/**)",
            "Edit(**/node_modules/**)",
            "Read(**/.git/**)",
