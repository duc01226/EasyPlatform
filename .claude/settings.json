            "Read(**/.env!(.example))",
            "Read(.env!(.example))",
            "Read(**/secrets/**)",
            "Read(**/credentials*)",
            "Read(~/.ssh/**)",
            "Read(~/.aws/**)",
            "Read(~/.config/gcloud/**)",
            "Write(**/.git/**)",
            "Write(.git/**)",
            "Write(**/.env!(.example))",
            "Write(.env!(.example))",
            "Write(**/secrets/**)",
            "Write(**/credentials*)",
