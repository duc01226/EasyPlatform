    },
    {
      "type": "text", "id": "ev_grep_vs_graph_text", "x": 65, "y": 918, "width": 280, "height": 73,
      "text": "grep 'UserController'  \u2192 0 results in Angular\ngrep 'AccountUserSavedEvent' \u2192 0 in Growth\n\ngraph trace UserController.cs\n  \u2192 finds Angular caller via API_ENDPOINT\n  \u2192 finds Growth consumer via MESSAGE_BUS", "originalText": "grep 'UserController'  \u2192 0 results in Angular\ngrep 'AccountUserSavedEvent' \u2192 0 in Growth\n\ngraph trace UserController.cs\n  \u2192 finds Angular caller via API_ENDPOINT\n  \u2192 finds Growth consumer via MESSAGE_BUS",
      "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle",
      "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 190003, "version": 1, "versionNonce": 190004, "isDeleted": false, "groupIds": [],
