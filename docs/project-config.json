    "graphConnectors": {
        "apiEndpoints": {
            "enabled": true,
            "frontend": {
                "framework": "angular",
                "paths": [
                    "src/Frontend/apps/playground-text-snippet/",
                    "src/Frontend/libs/apps-domains/text-snippet-domain/",
                    "src/Frontend/libs/platform-core/"
                ]
            },
            "backend": {
                "framework": "dotnet",
                "paths": ["src/Backend/PlatformExampleApp.TextSnippet.Api/Controllers/"],
                "routePrefix": "api"
            }
        },
        "implicitConnections": [
            {
                "name": "entity-definition-to-event-handlers",
                "description": "Entity classes → EntityEventApplicationHandlers that react to entity changes",
                "edgeKind": "MESSAGE_BUS",
                "paths": ["src/Backend/PlatformExampleApp.TextSnippet.Domain/", "src/Backend/PlatformExampleApp.TextSnippet.Application/UseCaseEvents/"],
                "source": {
                    "filePattern": "*.cs",
                    "contentPattern": "class\\s+(\\w+)\\s*:.*(?:RootEntity|RootAuditedEntity)<",
                    "keyGroup": 1
                },
                "target": {
                    "filePattern": "*.cs",
                    "contentPattern": "EntityEventApplicationHandler<(\\w+)",
                    "keyGroup": 1
                },
                "matchBy": "key-contains"
            },
            {
                "name": "entity-event-producers",
                "description": "Entity event bus producers that publish entity events to message bus",
                "edgeKind": "MESSAGE_BUS",
                "paths": ["src/Backend/PlatformExampleApp.TextSnippet.Application/MessageBus/Producers/"],
                "source": {
                    "filePattern": "*.cs",
                    "contentPattern": "EntityEventBusMessageProducer<(\\w+)",
                    "keyGroup": 1
                },
                "target": {
                    "filePattern": "*.cs",
                    "contentPattern": "(?:EntityEventBusMessageConsumer|PlatformApplicationMessageBusConsumer)<(\\w+)",
                    "keyGroup": 1
                },
                "matchBy": "key-contains"
            },
            {
                "name": "bus-message-producers-to-consumers",
                "description": "Message bus producers → consumers for entity events across services",
                "edgeKind": "MESSAGE_BUS",
                "paths": ["src/Backend/PlatformExampleApp.TextSnippet.Application/MessageBus/"],
                "source": {
                    "filePattern": "*.cs",
                    "contentPattern": "class\\s+(\\w+).*EntityEventBusMessageProducer<",
                    "keyGroup": 1
                },
                "target": {
                    "filePattern": "*.cs",
                    "contentPattern": "class\\s+(\\w+).*(?:EntityEventBusMessageConsumer|PlatformApplicationMessageBusConsumer)<",
                    "keyGroup": 1
                },
                "matchBy": "key-contains"
            },
            {
                "name": "free-format-bus-message-class-to-consumers",
                "description": "Free-format bus message classes → their consumers",
                "edgeKind": "MESSAGE_BUS",
                "paths": [
                    "src/Backend/PlatformExampleApp.TextSnippet.Application/MessageBus/FreeFormatMessages/",
                    "src/Backend/PlatformExampleApp.TextSnippet.Application/MessageBus/Consumers/FreeFormatConsumers/",
                    "src/Backend/PlatformExampleApp.Shared/Application/MessageBus/FreeFormatMessages/"
                ],
                "source": {
                    "filePattern": "*.cs",
                    "contentPattern": "class\\s+(\\w+).*(?:PlatformTrackableBusMessage|PlatformBusMessage|BusMessage)",
                    "keyGroup": 1
                },
                "target": {
                    "filePattern": "*.cs",
                    "contentPattern": "PlatformApplicationMessageBusConsumer<(\\w+)",
                    "keyGroup": 1
                },
                "matchBy": "key-contains"
            }
        ]
    }
}
