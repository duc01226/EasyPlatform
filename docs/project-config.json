        "fixturesPath": "src/Frontend/e2e/fixtures/",
        "guideDoc": "docs/project-reference/e2e-test-reference.md",
        "testSpecsDocs": ["docs/test-specs/"],
        "searchPatterns": ["test\\(", "\\.spec\\.ts$"],
        "runCommands": {
            "all": "cd src/Frontend/e2e && npx playwright test",
            "headed": "cd src/Frontend/e2e && npx playwright test --headed",
            "ui": "cd src/Frontend/e2e && npx playwright test --ui"
        },
        "bestPractices": [],
        "entryPoints": ["src/Frontend/e2e/playwright.config.ts", "src/Frontend/e2e/recordings/", "src/Frontend/e2e/utils/"]
    },
