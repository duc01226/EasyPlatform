                "pathRegexes": ["src[\\\\/]Frontend[\\\\/].*\\.scss$"],
                "description": "Block Element Modifier naming convention for all CSS classes",
                "scssExamples": ["block__element", "block__element--modifier"]
            },
            {
                "name": "SCSS Partials",
                "pathRegexes": ["src[\\\\/]Frontend[\\\\/]apps[\\\\/].*[\\\\/]styles[\\\\/]"],
                "description": "Shared styles via _variables.scss, _mixins.scss, _functions.scss, _placeholders.scss",
