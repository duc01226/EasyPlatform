    "contextGroups": [
        {
            "name": "backend",
            "pathRegexes": ["src[\\\\/]Backend[\\\\/]", "src[\\\\/]Platform[\\\\/]"],
            "fileExtensions": [".cs", ".csproj"],
            "patternsDoc": "docs/project-reference/backend-patterns-reference.md",
            "rules": [
                "Use IPlatformRootRepository<TEntity> for data access",
                "PlatformValidationResult fluent API — never throw exceptions",
                "Side effects in EntityEventHandlers (UseCaseEvents/), never in command handlers",
                "DTOs own mapping via MapToEntity()/MapToObject()",
                "Cross-service communication via RabbitMQ message bus only",
                "Command + Result + Handler in ONE file under UseCaseCommands/{Feature}/"
            ]
        },
        {
            "name": "frontend",
            "pathRegexes": ["src[\\\\/]Frontend[\\\\/]"],
            "fileExtensions": [".ts", ".html", ".scss"],
            "patternsDoc": "docs/project-reference/frontend-patterns-reference.md",
            "stylingDoc": "docs/project-reference/scss-styling-guide.md",
            "designSystemDoc": "docs/project-reference/design-system/README.md",
            "rules": [
                "Extend AppBaseComponent/AppBaseVmStoreComponent/AppBaseFormComponent",
                "Use PlatformVmStore + effectSimple() for state management",
                "Extend PlatformApiService for HTTP calls",
                "Always use .pipe(this.untilDestroyed()) for subscriptions",
                "All template elements must have BEM classes (block__element --modifier)",
                "Logic in lowest layer: Entity/Model > Service > Component"
            ]
        }
    ],
    "designSystem": {
        "docsPath": "docs/project-reference/design-system",
        "modernUiNote": "Angular 19 + Angular Material 19 with custom theme",
        "appMappings": [
            {
                "name": "playground-text-snippet",
                "pathRegexes": ["src[\\\\/]Frontend[\\\\/]apps[\\\\/]playground-text-snippet[\\\\/]"],
                "docFile": "docs/project-reference/design-system/README.md",
                "description": "TextSnippet example app frontend"
            }
        ]
    },
    "styling": {
        "technology": "scss",
        "fileExtensions": [".scss"],
        "guideDoc": "docs/project-reference/scss-styling-guide.md",
        "appMap": {
            "playground-text-snippet": "src[\\\\/]Frontend[\\\\/]apps[\\\\/]playground-text-snippet[\\\\/].*\\.scss$"
        },
        "patterns": [
            {
                "name": "component-styles",
                "pathRegexes": ["src[\\\\/]Frontend[\\\\/].*\\.component\\.scss$"],
                "description": "Component-scoped SCSS files using BEM naming",
                "scssExamples": [".block__element--modifier { }"]
            },
            {
                "name": "global-styles",
                "pathRegexes": ["src[\\\\/]Frontend[\\\\/]apps[\\\\/].*[\\\\/]src[\\\\/]styles[\\\\/].*\\.scss$"],
                "description": "Global styles and Material component overrides"
            }
        ]
    },
    "componentSystem": {
        "type": "angular",
        "selectorPrefixes": ["app-", "platform-example-web-"],
        "filePattern": "*.component.ts",
        "layerClassification": {
            "platform-core": "src[\\\\/]Frontend[\\\\/]libs[\\\\/]platform-core[\\\\/]",
            "platform-components": "src[\\\\/]Frontend[\\\\/]libs[\\\\/]platform-components[\\\\/]",
            "shared-components": "src[\\\\/]Frontend[\\\\/]libs[\\\\/]apps-shared-components[\\\\/]",
            "domain-components": "src[\\\\/]Frontend[\\\\/]libs[\\\\/]apps-domains-components[\\\\/]",
            "app-components": "src[\\\\/]Frontend[\\\\/]apps[\\\\/]"
        }
    },
    "testing": {
        "frameworks": ["xunit", "playwright", "jest"],
        "filePatterns": {
            "unit-backend": "*.Test.cs",
            "integration-backend": "*IntegrationTests*.cs",
            "bdd-backend": "*.feature",
            "unit-frontend": "*.spec.ts",
            "e2e-frontend": "e2e/**/*.spec.ts"
        },
        "commands": {
            "backend-unit": "dotnet test src/Backend/PlatformExampleApp.Test/",
            "backend-integration": "dotnet test src/Backend/PlatformExampleApp.IntegrationTests/",
            "backend-bdd": "dotnet test src/Backend/PlatformExampleApp.Test.BDD/",
            "frontend-unit": "cd src/Frontend && npm test",
            "e2e": "cd src/Frontend/e2e && npx playwright test"
        },
        "guideDoc": "docs/project-reference/integration-test-reference.md"
    },
    "e2eTesting": {
        "framework": "playwright",
        "language": "typescript",
        "configFile": "src/Frontend/e2e/playwright.config.ts",
        "testsPath": "src/Frontend/e2e/tests/",
        "pageObjectsPath": "src/Frontend/e2e/page-objects/",
        "fixturesPath": "src/Frontend/e2e/fixtures/",
        "guideDoc": "docs/project-reference/e2e-test-reference.md",
        "testSpecsDocs": [],
        "searchPatterns": ["test\\(['\"]TC-", "\\.spec\\.ts$"],
        "runCommands": {
            "all": "cd src/Frontend/e2e && npx playwright test",
            "headed": "cd src/Frontend/e2e && npx playwright test --headed",
            "ui": "cd src/Frontend/e2e && npx playwright test --ui",
            "smoke": "cd src/Frontend/e2e && npx playwright test --grep @P0",
            "debug": "cd src/Frontend/e2e && npx playwright test --debug"
        },
        "tcCodeFormat": "TC-{MODULE}-{AREA}-{NNN}",
        "bestPractices": [],
        "entryPoints": ["src/Frontend/e2e/playwright.config.ts", "src/Frontend/e2e/fixtures/test-data.ts", "src/Frontend/e2e/page-objects/base.page.ts"]
    },
    "databases": {
        "primary": "MongoDB",
        "alternatives": ["PostgreSQL", "SQL Server"],
        "note": "Multi-database support — each persistence layer is a separate module"
    },
    "messaging": {
        "broker": "RabbitMQ",
        "patterns": ["entity-event-bus", "free-format-messages", "inbox-outbox"],
        "consumerConvention": "PlatformApplicationMessageBusConsumer<TMessage>"
    },
    "api": {
        "style": "REST",
        "docsFormat": "swagger",
        "authPattern": "JWT + ASP.NET Core Identity"
    },
    "infrastructure": {
        "containerization": "docker",
        "orchestration": "docker-compose",
        "cicd": {
            "tool": "docker-compose",
            "configPath": "src/platform-example-app.docker-compose.yml"
        }
    },
