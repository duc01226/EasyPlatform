    "testing": {
        "frameworks": ["xunit", "jest", "playwright"],
        "filePatterns": {
            "backend-unit": "*.Test.cs",
            "backend-integration": "*IntegrationTest*.cs",
            "backend-bdd": "*.BDD/*.cs",
