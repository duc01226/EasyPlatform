    "contextGroups": [
        {
            "name": "backend",
            "pathRegexes": ["src[\\\\/]Backend[\\\\/].*\\.cs$"],
            "fileExtensions": [".cs"],
            "guideDoc": "docs/project-reference/backend-patterns-reference.md",
            "patternsDoc": "docs/project-reference/backend-patterns-reference.md",
            "rules": [
                "Use IPlatformRootRepository<TEntity> for data access",
                "Use PlatformValidationResult fluent API, never throw exceptions for validation",
                "Side effects go in Entity Event Handlers (UseCaseEvents/), never in command handlers",
                "DTOs own mapping via MapToEntity()/MapToObject(), never map in handlers",
                "Cross-service communication via RabbitMQ message bus only",
                "Command + Result + Handler in ONE file under UseCaseCommands/{Feature}/"
            ]
        },
        {
            "name": "frontend",
            "pathRegexes": ["src[\\\\/]Frontend[\\\\/].*\\.(ts|html|scss)$"],
            "fileExtensions": [".ts", ".html", ".scss"],
            "guideDoc": "docs/project-reference/frontend-patterns-reference.md",
            "patternsDoc": "docs/project-reference/frontend-patterns-reference.md",
            "stylingDoc": "docs/project-reference/scss-styling-guide.md",
            "designSystemDoc": "docs/project-reference/design-system/README.md",
            "rules": [
                "Extend AppBaseComponent/AppBaseVmStoreComponent/AppBaseFormComponent",
                "Use PlatformVmStore + effectSimple() for state management",
                "Extend PlatformApiService for HTTP calls, never use HttpClient directly",
                "Always use .pipe(this.untilDestroyed()) for subscriptions",
                "All template elements must have BEM classes (block__element --modifier)",
                "Constants/columns/roles go in Model class static properties, not Components"
            ]
        },
        {
            "name": "platform-framework",
            "pathRegexes": ["src[\\\\/]Platform[\\\\/].*\\.cs$"],
            "fileExtensions": [".cs"],
            "guideDoc": "docs/project-reference/backend-patterns-reference.md",
            "patternsDoc": "docs/project-reference/backend-patterns-reference.md",
            "rules": [
                "This is the framework layer - changes affect all consumers",
                "Maintain backward compatibility for public APIs",
                "Document breaking changes in CHANGELOG"
            ]
        }
    ],
    "designSystem": {
        "docsPath": "docs/project-reference/design-system",
        "appMappings": [
            {
